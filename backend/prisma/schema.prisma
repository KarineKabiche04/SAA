generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  fullName  String?
  role      String     @default("user")
  createdAt DateTime   @default(now())
  devis     Devis[]
  sinistres Sinistre[]
  vehicules Vehicule[]
  conversations Conversation[]
}

model Vehicule {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  marque        String
  immatriculation String
  energie       String   @default("ESSENCE")
  dateEcheance  DateTime
  statut        String   @default("ACTIF")
  garanties     String   @default("RC,DR")
  prime         Float    @default(0)
  createdAt     DateTime @default(now())
}

model Devis {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  contenu   String
  statut    String   @default("en attente")
  createdAt DateTime @default(now())
}

model Sinistre {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  ref       String
  type      String
  lieu      String?
  statut    String   @default("EN COURS")
  montant   Float    @default(0)
  contenu   String
  createdAt DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  nom         String
  description String
  prix        Float
  image       String?
  createdAt   DateTime @default(now())
}
model DemandeCompte {
  id             Int      @id @default(autoincrement())
  nom            String
  email          String
  telephone      String
  marque         String
  immatriculation String
  wilaya         String
  message        String?
  statut         String   @default("EN ATTENTE")
  createdAt      DateTime @default(now())
}
model Conversation {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  contenu        String
  expediteur     String       @default("client")
  lu             Boolean      @default(false)
  createdAt      DateTime     @default(now())
}